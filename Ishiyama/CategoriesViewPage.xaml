<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Ishiyama.CategoriesViewPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Ishiyama"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewmodels="using:Kara.ViewModels"
    d:DataContext="{d:DesignInstance Type=viewmodels:CategoriesViewModel}"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <TextBlock
            x:Uid="DescCategories"
            Style="{StaticResource BodyTextBlockStyle}"/>
        <local:CategoriesView
            x:Name="SpecialView"
            Grid.Row="1"/>
        <CommandBar
            DefaultLabelPosition="Collapsed"
            Grid.Row="2">
            <AppBarButton
                x:Uid="AddBtn"
                Icon="Add"
                Command="{Binding AddCommand}"/>
            <AppBarButton
                x:Uid="AddSmBtn"
                Icon="Add"
                Command="{Binding AddSmallCommand}"
                CommandParameter="{Binding SelectedItem, ElementName=SpecialView}"/>
            <AppBarButton
                x:Uid="DltBtn"
                Icon="Delete">
                <AppBarButton.Flyout>
                    <Flyout>
                        <StackPanel>
                            <TextBlock
                                Style="{StaticResource BaseTextBlockStyle}"
                                x:Uid="Confirm"/>
                            <Button
                                x:Uid="DltCBtn"
                                Command="{Binding RemoveCommand}"
                                CommandParameter="{Binding ElementName=SpecialView, Path=SelectedItem}"/>
                        </StackPanel>
                    </Flyout>
                </AppBarButton.Flyout>
            </AppBarButton>
            <AppBarButton
                x:Uid="LdBtn"
                Icon="Sync"
                Command="{Binding LoadCommand}"/>
            <AppBarButton
                x:Uid="DetailBtn"
                Icon="Manage"
                Command="{Binding DetailCommand}"
                CommandParameter="{Binding SelectedItem, ElementName=SpecialView}"/>
        </CommandBar>
    </Grid>
</Page>
