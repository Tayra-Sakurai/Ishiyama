<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Ishiyama.LargeCategoryViewPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Ishiyama"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <XamlUICommand
            x:Key="GoBackCommand"
            x:Name="GoBackCommand"
            ExecuteRequested="GoBackCommand_ExecuteRequested"
            CanExecuteRequested="GoBackCommand_CanExecuteRequested"/>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock
            x:Uid="LargeCategoryEditDesc"/>
        <TextBox
            Grid.Row="1"
            x:Uid="NameBox"/>
        <CommandBar
            Grid.Row="2"
            DefaultLabelPosition="Bottom">
            <AppBarButton
                Icon="Back"
                x:Uid="BkBtn"
                Command="{StaticResource GoBackCommand}"/>
            <AppBarButton
                Icon="Save"
                x:Uid="SvBtn"
                Command="{x:Bind viewModel.SaveCommand}"/>
            <AppBarButton
                Icon="Delete"
                x:Uid="DltBtn">
                <AppBarButton.Flyout>
                    <Flyout>
                        <StackPanel>
                            <TextBlock
                                x:Uid="Confirm"
                                Style="{StaticResource BaseTextBlockStyle}"/>
                            <Button
                                x:Uid="DltCBtn"
                                Style="{StaticResource AccentButtonStyle}"
                                Command="{x:Bind viewModel.RemoveCommand}"/>
                        </StackPanel>
                    </Flyout>
                </AppBarButton.Flyout>
            </AppBarButton>
        </CommandBar>
    </Grid>
</Page>
