<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Ishiyama.CategoryViewPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Ishiyama"
    xmlns:local2="using:Ishiyama.TemplatedElements"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:Kara.Models"
    mc:Ignorable="d">

    <Grid
        RowSpacing="4"
        ColumnSpacing="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock
            x:Uid="CategoryEditDesc"
            Style="{StaticResource BodyTextBlockStyle}"
            VerticalAlignment="Top"
            HorizontalAlignment="Stretch"
            HorizontalTextAlignment="Start"/>
        <local2:ValidationTextBox
            x:Uid="CategoryNameBox"
            Grid.Row="1"
            Text="{x:Bind viewModel.Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
            PropertyName="Name"
            DataContext="{x:Bind viewModel}"/>
        <ComboBox
            x:Uid="CategoryComboBox"
            ItemsSource="{x:Bind viewModel.Categories}"
            SelectedItem="{x:Bind viewModel.Parent, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
            Grid.Row="2">
            <ComboBox.ItemTemplate>
                <DataTemplate x:DataType="models:Category">
                    <TextBlock Text="{x:Bind Name, TargetNullValue=Null}"/>
                </DataTemplate>
            </ComboBox.ItemTemplate>
            <ComboBox.ItemContainerStyle>
                <Style
                    TargetType="ComboBoxItem"
                    BasedOn="{StaticResource DefaultComboBoxItemStyle}"/>
            </ComboBox.ItemContainerStyle>
        </ComboBox>
        <CommandBar
            Grid.Row="3"
            DefaultLabelPosition="Right">
            <AppBarButton
                Icon="Save"
                x:Uid="SvBtn"
                Command="{x:Bind viewModel.SaveCommand}"/>
            <AppBarButton
                Icon="Sync"
                x:Uid="SyncBtn"
                Command="{x:Bind viewModel.LoadCommand}"/>
            <AppBarButton
                Icon="Delete"
                x:Uid="DltBtn">
                <AppBarButton.Flyout>
                    <Flyout>
                        <StackPanel>
                            <TextBlock
                                Style="{StaticResource BaseTextBlockStyle}"
                                x:Uid="Confirm"/>
                            <Button
                                x:Uid="DltCBtn"
                                Command="{x:Bind viewModel.RemoveCommand}"/>
                        </StackPanel>
                    </Flyout>
                </AppBarButton.Flyout>
            </AppBarButton>
        </CommandBar>
    </Grid>
</Page>
